{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm src/*)",
      "Bash(rm tests/*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.cert)",
      "Bash(rm -rf *)",
      "Read(.prds/*)",
      "Glob(.prds/*)",
      "Grep(.prds/*)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(rm src/*)",
      "Bash(rm tests/*)",
      "Write(.github/scripts/ralph.sh)",
      "Edit(.github/scripts/ralph.sh)",
      "Bash(*.github/scripts/ralph.sh*)",
      "Write(.github/prompts/ralph.md)",
      "Edit(.github/prompts/ralph.md)",
      "Bash(*.github/prompts/ralph.md*)"
    ]
  }
}
